    "babel-preset-expo": "~12.0.0",
    "eslint": "^8.57.0",
    "eslint-config-universe": "^12.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.8.0",
    "eas-cli": "^16.0.0"
